<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STUDIOPRO.AI</title>

<style>
*{margin:0;padding:0;box-sizing:border-box}
body{
  font-family: Arial, sans-serif;
  background:#0b0d0f;
  color:#fff;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:20px 40px;
  position:fixed;
  width:100%;
  top:0;
  backdrop-filter:blur(10px);
}
.logo{font-weight:900}
.logo span{color:#00ff88}

/* HERO */
.hero{
  height:100vh;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  padding:20px;
}
.hero h1{
  font-size:70px;
  line-height:1;
}
.hero span{color:#00ff88}

.btn{
  background:#00ff88;
  color:#000;
  padding:15px 35px;
  margin-top:30px;
  text-decoration:none;
  font-weight:bold;
  transition:0.3s;
}
.btn:hover{opacity:0.8}

/* SECTIONS */
.section{
  padding:100px 20px;
  text-align:center;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
  margin-top:40px;
}

.card{
  background:#15181c;
  padding:30px;
  border-radius:10px;
  transition:0.3s;
}
.card:hover{
  transform:translateY(-5px);
  background:#1c2025;
}

/* CTA */
.cta{
  background:linear-gradient(135deg,#00ff88,#00cc66);
  color:#000;
  padding:80px 20px;
}

/* FOOTER */
footer{
  text-align:center;
  padding:30px;
  opacity:0.5;
}
</style>
</head>

<body>

<nav>
  <div class="logo">STUDIO<span>PRO.AI</span></div>
  <a href="https://flippa.com" class="btn">Flippa</a>
</nav>

<div class="hero">
  <h1>The Future of <br><span>AI SaaS</span></h1>
  <p>Video, Image & Content generation platform ready for acquisition.</p>
  <a href="https://flippa.com" class="btn">Buy on Flippa</a>
</div>

<div class="section">
  <h2>All-in-One AI Platform</h2>
  <div class="grid">
    <div class="card">🎬 AI Video Generator</div>
    <div class="card">🖼️ AI Image Generator</div>
    <div class="card">✍️ Content Studio</div>
    <div class="card">💰 Monetization System</div>
  </div>
</div>

<div class="section">
  <h2>Why This Project?</h2>
  <p>✔ Ready SaaS<br>✔ AI Market Growing<br>✔ Scalable & Automated</p>
</div>

<div class="cta">
  <h2>Ready to Acquire?</h2>
  <p>Get full ownership of this AI SaaS today.</p>
  <a href="https://flippa.com" class="btn">Make Offer</a>
</div>

<footer>
  STUDIOPRO.AI — AI SaaS Platform for Sale
</footer>

</body>
</html>
